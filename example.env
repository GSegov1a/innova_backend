DATABASE_URL=postgresql://user:password@host:5432/dbname
OPENAI_API_KEY=your_api_key_here
OPENAI_REALTIME_MODEL=gpt-realtime-mini
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_NOISE_REDUCTION=near_field
OPENAI_REALTIME_VAD_THRESHOLD=0.85
OPENAI_REALTIME_VAD_PREFIX_MS=300
OPENAI_REALTIME_VAD_SILENCE_MS=1200
OPENAI_REALTIME_VAD_INTERRUPT_RESPONSE=false
RASPBERRY_DEVICE_TOKEN=change_me
